PORT=5000
MONGO_URI=your_mongodb_connection_string
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:5173

# SMTP config for the "forgot password" email, set up for Gmail.
# 1. Turn on 2-Step Verification on the Gmail account: myaccount.google.com/security
# 2. Create an App Password: myaccount.google.com/apppasswords (choose "Mail")
# 3. Paste the 16-character app password below as SMTP_PASS (NOT your normal Gmail password)
# Leave SMTP_USER/SMTP_PASS blank in local dev to just log the code to the console instead.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Talabaty <your-gmail-address@gmail.com>
